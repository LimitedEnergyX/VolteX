# VolteX Discord operator interface -- local config template.
# Copy this file to .env in this same folder and fill in real values.
# NEVER commit .env. Only this .env.example is tracked.

# Discord bot token from the Discord Developer Portal. Keep this secret.
DISCORD_BOT_TOKEN=

# Numeric IDs. Enable Developer Mode in Discord, then right-click to copy ID.
VOLTEX_GUILD_ID=
VOLTEX_ALLOWED_USER_ID=
VOLTEX_ALLOWED_CHANNEL_ID=
